# =============================================================================
# VARIABLES DE ENTORNO - SISTEMA DE GESTIÓN DOCUMENTAL ASERGES S.L.
# =============================================================================
#
# Copie este archivo a .env y rellene los valores correspondientes.
# NO INCLUYA este archivo .env en el control de versiones (Git).

# --- Configuración del Worker (judicial_worker.py) ---

# Puerto en el que escuchará el servidor Flask
WORKER_PORT=8765

# Ruta base donde se guardarán los PDFs procesados en Windows
# Use dobles barras invertidas para las rutas de Windows
ESCANER_BASE=C:\\Escaner

# Directorio para PDFs que no se pudieron vincular a un expediente
PENDIENTES_DIR=C:\\Escaner\\_Pendientes

# Ruta al ejecutable de Tesseract OCR (si no está en el PATH del sistema)
TESSERACT_CMD=C:\\Program Files\\Tesseract-OCR\\tesseract.exe

# --- Configuración de la Base de Datos (SQL Server - Mnprogram) ---

# Dirección del servidor SQL Server
SQL_SERVER=192.168.1.100

# Nombre de la base de datos de Mnprogram
SQL_DATABASE=MnProgram

# Usuario de SQL Server (si no se usa autenticación de Windows)
SQL_USER=usuario_sql

# Contraseña del usuario de SQL Server
SQL_PASSWORD=contraseña_segura

# ¿Usar autenticación de Windows (Trusted Connection)? (yes/no)
# Si es 'yes', se ignoran SQL_USER y SQL_PASSWORD
SQL_TRUSTED_CONNECTION=no

# Driver ODBC para SQL Server (generalmente no necesita cambiarse)
SQL_DRIVER={ODBC Driver 17 for SQL Server}


# --- Configuración de la API SOAP de Mnprogram (Opcional) ---

# ¿Habilitar el uso de la API SOAP? (true/false)
USE_SOAP_API=false

# URL del servicio web de Mnprogram (si aplica)
# Ejemplo: http://cloud.mnprogram.net
MNPROGRAM_API_URL=

# Número de empresa en Mnprogram (normalmente 2)
MNPROGRAM_EMPRESA=2

# Usuario de Mnprogram con permisos de API (Supervisor)
MNPROGRAM_OPERADOR=Supervisor

# Contraseña del usuario de Mnprogram en formato MD5
MNPROGRAM_PASS_MD5=

# Instancia (para versiones Cloud)
MNPROGRAM_INSTANCIA=

# Token de API (para versiones Cloud, solicitar a Mnprogram)
MNPROGRAM_TOKEN=


# --- Configuración del Scraper de LexNET (lexnet_scraper.py) ---

# URL del worker para enviar los documentos procesados
WORKER_URL=http://localhost:8765/procesar

# Ruta al directorio de datos de usuario de Chrome en Windows
# Suele ser la ruta por defecto, no necesita cambiarse
CHROME_USER_DATA_DIR=%LOCALAPPDATA%\\Google\\Chrome\\User Data

# Perfil de Chrome donde está instalado el certificado digital
# 'Default' es el perfil principal. Si usa otro, cámbielo aquí.
CHROME_PROFILE=Default

# Ruta al ejecutable de Chrome (si no está en la ubicación estándar)
CHROME_EXECUTABLE=C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe

# Directorio temporal para descargar los PDFs de LexNET
LEXNET_DOWNLOAD_DIR=C:\\Escaner\\_LexNET_Temp


# --- Configuración del Flujo n8n (n8n_flow.json) ---
# Estas variables se configuran en el entorno del servidor n8n

# URL del worker (accesible desde el servidor n8n)
# N8N_WORKER_URL=http://<IP_PC_WINDOWS>:8765/procesar

# Email desde el que se enviarán las notificaciones
# N8N_EMAIL_FROM=notificaciones@aserges.es

# Email del administrador que recibirá las alertas y confirmaciones
# N8N_EMAIL_ADMIN=admin@aserges.es
